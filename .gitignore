# -----------------------------
# OS / filesystem noise
# -----------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# -----------------------------
# Editor / IDE
# -----------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------
# Logs / temp
# -----------------------------
*.log
*.tmp
*.temp
tmp/
temp/

# -----------------------------
# Env / secrets
# -----------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# -----------------------------
# Python (if any tooling/scripts are added later)
# -----------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage/
htmlcov/

# -----------------------------
# Node/web tooling (future-proof)
# -----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.cache/
.parcel-cache/

# -----------------------------
# Dashboard data policy
# -----------------------------
# Keep directory in repo, allow tracked data artifact
dashboard-data/*
!dashboard-data/.gitkeep
!dashboard-data/latest.json
